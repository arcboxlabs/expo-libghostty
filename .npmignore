# Exclude all top-level hidden directories by convention
/.*/

# Exclude tarballs generated by `npm pack`
/*.tgz

/internal/module_scripts/
/android/build/
/example/

# Fetched at install time by scripts/download-xcframework.mjs
/ios/vendor/Frameworks/

# Repo tooling, useless to consumers
/.envrc
/.prettierrc
/devenv.nix
/devenv.yaml
/devenv.lock
/eslint.config.cjs
/pnpm-workspace.yaml
/tsconfig.json
